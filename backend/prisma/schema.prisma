generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User profiles (extends Supabase auth.users)
model Profile {
  id         String   @id @db.Uuid
  email      String   @unique
  full_name  String?
  avatar_url String?
  phone      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("profiles")
}
